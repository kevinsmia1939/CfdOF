%{%(fvOptionsFilePresent%)
%:True
%[_header%]
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

%{%(fvOptions%)
%(0%)
{
    type            meanVelocityForce;
    selectionMode   all;
%{%(fvOptions/%(0%)/Active%)
%:True
    active          yes;
%:default
    active          no;
%}

    meanVelocityForceCoeffs
    {
        selectionMode   all;
        fields          (U);
        direction       (%(fvOptions/%(0%)/DirectionTuple%));
        Ubar            (%(fvOptions/%(0%)/UbarTuple%));
        relaxation      %(fvOptions/%(0%)/Relaxation%);
    }
}

%}
%{%(scalarTransportFunctionsEnabled%)
%:True
%{%(scalarTransportFunctions%)
%(0%)
{
    type            semiImplicitSource;
    selectionMode   points;
    points
    (
        ( %(scalarTransportFunctions/%(0%)/InjectionPoint%) )
    );

    volumeMode      absolute;
    sources
    {
        %(scalarTransportFunctions/%(0%)/FieldName%)
        {
            explicit %(scalarTransportFunctions/%(0%)/InjectionRate%);
            implicit 0;
        }
    }

}

%}
%}

//************************************************************************ //
%}
